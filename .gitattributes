# Auto detect text files and perform LF normalization
* text=auto

# TypeScript/Vue/JS
*.ts text eol=lf
*.tsx text eol=lf
*.vue text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.mjs text eol=lf
*.cjs text eol=lf

# Web
*.html text eol=lf
*.css text eol=lf
*.scss text eol=lf

# Config
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.toml text eol=lf
*.md text eol=lf

# Shell scripts
*.sh text eol=lf

# Binary - no diff
*.jpg binary
*.jpeg binary
*.png binary
*.gif binary
*.ico binary
*.webp binary
*.mp3 binary
*.wav binary
*.ogg binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.pdf binary
